const int LED_PIN = 10;
const int BAUD_RATE = 9600;

void setup() {
  Serial.begin(BAUD_RATE);
  pinMode(LED_PIN, OUTPUT);
  analogWrite(LED_PIN, 0);  // إطفاء LED في البداية
  Serial.println("Arduino LED Controller Ready");
  delay(500);
}

void loop() {
  // قراءة السطر كامل من Serial
  if (Serial.available() > 0) {
    String input = Serial.readStringUntil('\n');
    input.trim();  // إزالة المسافات الزائدة
    
    if (input.length() > 0) {
      int pwm_value = input.toInt();
      
      // التحقق من أن القيمة في النطاق الصحيح
      if (pwm_value >= 0 && pwm_value <= 255) {
        analogWrite(LED_PIN, pwm_value);
        Serial.print("LED PWM set to: ");
        Serial.println(pwm_value);
      } else {
        Serial.println("Invalid value. Range is 0-255");
      }
    }
  }
}

