#include <Keypad.h>

char key[4][4]={
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte colPin[4]={5,4,3,2};
byte rowPin[4]={9,8,7,6};
Keypad keypad = Keypad (makeKeymap(key),rowPin,colPin,4,4);

void setup(){
  pinMode(11, OUTPUT);
  pinMode(12, OUTPUT);
  pinMode(13, OUTPUT);
 
}

void loop(){
	char key = keypad.getKey();
  
  if(key =='1' ){
    digitalWrite(11, HIGH);
  	
  }
  if (key =='2' ){
    digitalWrite(12, HIGH);}
  if (key =='3' ){
    digitalWrite(13, HIGH);}
  if (key =='*' ){
    digitalWrite(11, 0);digitalWrite(12, 0);digitalWrite(13, 0);}
  
}
